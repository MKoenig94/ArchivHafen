# Optional: Ablageort des Archivs. Standard: $XDG_DATA_HOME/archivhafen
ARCHIVHAFEN_DATA_DIR=/home/your-user/.local/share/archivhafen

# Optional: fester Schlüssel, beispielsweise aus einem Secret Store.
# Bleibt dieser Wert leer, erzeugt Archiv Hafen data/master.key mit Modus 0600.
# ARCHIVHAFEN_MASTER_KEY=

ARCHIVHAFEN_HOST=127.0.0.1
ARCHIVHAFEN_PORT=4174

# Nur Docker Compose: veröffentlichter Port auf dem Linux-Host.
ARCHIVHAFEN_HTTP_PORT=4174

# Automatische Archivierung; 0 deaktiviert sie.
ARCHIVHAFEN_SYNC_INTERVAL_MINUTES=15
